{
  "name": "@diplodoc/package-template",
  "version": "2.0.0",
  "description": "Template package for Diplodoc platform development",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "homepage": "https://diplodoc.com/",
  "engines": {
    "npm": ">=11.5.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diplodoc-platform/package-template.git"
  },
  "bugs": {
    "url": "https://github.com/diplodoc-platform/diplodoc/issues"
  },
  "private": true,
  "author": "",
  "license": "MIT",
  "files": [
    "build"
  ],
  "scripts": {
    "build": "npm run build:clean && npm run build:js && npm run build:declarations",
    "build:js": "node esbuild/build.mjs",
    "build:declarations": "tsc --project tsconfig.publish.json --emitDeclarationOnly --outDir ./build",
    "build:clean": "rm -rf build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "lint",
    "lint:fix": "lint fix",
    "pre-commit": "lint-staged",
    "prepare": "husky || true",
    "prepublishOnly": "npm run build",
    "lock": "npm install --no-workspaces --package-lock-only --ignore-scripts"
  },
  "devDependencies": {
    "@diplodoc/infra": "2.2.0",
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.0"
  }
}
